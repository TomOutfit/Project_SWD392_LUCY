PORT=3001

# .NET Identity & Payment Service URL
# - Local dev: http://localhost:5001
# - Render Docker: set this to the internal Docker network URL (e.g. http://net-service:5001)
#   OR rely on NET_SERVICE_BASE_URL if your Render service uses internal networking.
NET_SERVICE_URL=http://localhost:5001
NET_SERVICE_BASE_URL=http://localhost:5001

# Agora credentials — get from https://console.agora.io
# Replace with your actual App ID and App Certificate
AGORA_APP_ID=..
AGORA_APP_CREDENTIAL=..
